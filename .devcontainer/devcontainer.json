{
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs",
        "donjayamanne.git-extension-pack",
        "codezombiech.gitignore",
        "github.vscode-github-actions",
        "ziyasal.vscode-open-in-github",
        "elagil.pre-commit-helper"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/workspaces/toolspaedeia/.venv/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.linting.ruffEnabled": true,
        "python.terminal.activateEnvironment": false,
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "PATH": "/workspaces/toolspaedeia/.venv/bin:${env:PATH}"
        }
      }
    }
  },
  "dockerFile": "../Dockerfile",
  "forwardPorts": [
    8888
  ],
  "name": "Django Dev Container",
  "overrideCommand": true,
  "postCreateCommand": "uv sync --locked --extra dev && rm -rf /app/.venv",
  "postStartCommand": "rm -rf /app/.venv",
  "remoteEnv": {
    "UV_PROJECT_ENVIRONMENT": "/workspaces/toolspaedeia/.venv"
  }
}
