graph TB
    subgraph "Browser / Client"
        direction TB
        HTMX["HTMX\n(actualizări parțiale DOM)"]
        SW["Service Worker\n(caching offline)"]
        PICO["Pico CSS\n(framework UI)"]
        MATHJAX["MathJax\n(redare formule)"]
    end

    subgraph "Django Application Server"
        direction TB

        subgraph "Aplicația courses"
            direction TB
            C_MODELS["Models\nCourse, Module, Quiz,\nQuestion, Answer,\nCourseTag, ModuleProgression,\nQuizAttempt, Resource"]
            C_VIEWS["Views\nCourseBrowseList, CourseDetail,\nCourseModuleDetail,\nModuleMarkComplete, AttemptQuiz"]
            C_TEMPLATES["Templates\ncourse_list, course_detail,\ncourse_module_detail\n+ fragmente HTMX"]
            C_ADMIN["Admin\nCourseAdmin (nested),\nQuizAdmin, CourseTagAdmin"]
            C_IMPORT["import_export.py\nImport/export cursuri Markdown"]
            C_MARKDOWN["markdown.py\nRedare Markdown în HTML"]
            C_SUGGEST["suggestions.py\nSugestii etichete\n(Sentence-Transformers)"]
            C_QUIZ["quizzes.py\nLogică notare quiz"]
        end

        subgraph "Aplicația purchases"
            direction TB
            P_MODELS["Models\nPurchase"]
            P_VIEWS["Views\nEnrollCourse, CreateRefund,\nPublisherIncome,\nStripeWebhook,\nEnrollmentDialog"]
        end

        subgraph "Aplicația users"
            direction TB
            U_MODELS["Models\nUserSitePreferences"]
            U_VIEWS["Views\nUserAccount, UserPreferences,\nToggleTagPreference"]
            U_FORMS["Forms\nLoginForm"]
            U_MIDDLEWARE["Middleware\nThemeCookieMiddleware"]
            U_CTX["Context Processors\nPreferințe utilizator globale"]
        end

        subgraph "Aplicația pwa"
            direction TB
            PWA_MANIFEST["manifest.json"]
            PWA_SW["serviceworker.js"]
            PWA_OFFLINE["Pagina offline"]
        end
    end

    subgraph "Baza de date"
        DEV_DB["SQLite3\n(dezvoltare)"]
        PROD_DB["MySQL\n(producție)"]
    end

    subgraph "Servicii externe"
        STRIPE["Stripe API"]
        HF["Hugging Face\n(model ML descărcat)"]
    end

    HTMX -->|"cereri HTTP parțiale"| C_VIEWS
    HTMX -->|"cereri HTTP parțiale"| P_VIEWS
    SW -->|"cache / intercept"| HTMX

    C_VIEWS --> C_MODELS
    C_VIEWS --> C_TEMPLATES
    C_VIEWS --> C_MARKDOWN
    C_ADMIN --> C_IMPORT
    C_ADMIN --> C_SUGGEST
    C_ADMIN --> C_MODELS
    C_QUIZ --> C_MODELS

    P_VIEWS --> P_MODELS
    P_VIEWS --> C_MODELS
    P_VIEWS -->|"Checkout + Webhook"| STRIPE

    U_VIEWS --> U_MODELS
    U_MIDDLEWARE --> U_MODELS

    C_MODELS --> DEV_DB
    C_MODELS --> PROD_DB
    P_MODELS --> DEV_DB
    P_MODELS --> PROD_DB
    U_MODELS --> DEV_DB
    U_MODELS --> PROD_DB

    C_SUGGEST -->|"încărcare model"| HF
